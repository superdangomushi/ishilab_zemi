# AIHelper サーバー設定サンプル。
# このファイルを .env にコピーして値を編集してください（.env は git 管理外）。
#   cp .env.example .env
# server.js が起動時に .env を読み込みます（既に設定済みの環境変数が優先されます）。

# ---- サーバー ----
PORT=3000

# ---- MySQL 接続 ----
# make db で作成する専用ユーザーに合わせる（既定は aihelper/aihelper）。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aihelper
DB_USER=aihelper
DB_PASSWORD=aihelper

# ---- Gemini（課題/予定の抽出・要約・秘書チャット）----
# 未設定だと抽出/要約/チャットは無効（受信・保存は動作します）。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ---- LINE 通知（任意）----
# 未設定だと LINE 送信はスキップ（端末ローカル通知だけ機能）。
LINE_CHANNEL_ACCESS_TOKEN=

# ---- リマインド/要約ジョブ ----
# 締切チェックの間隔（秒）
REMINDER_INTERVAL_SEC=60
# 「今日の要約」自動再生成の間隔（分）。0 で無効
DAILY_SUMMARY_INTERVAL_MIN=60
# 日次サマリの LINE 送信時刻（サーバーのローカル時刻, HH:MM）
DAILY_SUMMARY_TIME=21:00

# ---- Moodle 連携 ----
# 各ユーザーの Moodle iCal を定期取り込みする間隔（時間）。0 で無効。
# URL 自体はアプリ/ダッシュボードのアカウント画面で各ユーザーが登録します。
MOODLE_SYNC_INTERVAL_HOURS=6

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 録音 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- フォアグラウンドサービス（常時録音） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- 画面OFFでも録音/推論を継続 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 通知(Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- リマインドの全画面アラート＋バイブ -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- モデルの初回ダウンロード -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 1日のまとめ通知を指定時刻ちょうどに出す（Android 12+ はユーザー許可制） -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- 再起動後もまとめ通知・リマインドのアラームを貼り直す -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 締切リマインドの全画面アラート（ロック中でも表示・点灯） -->
        <activity
            android:name=".ReminderAlertActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <service
            android:name=".service.AudioCaptureService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <receiver
            android:name=".service.MicControlReceiver"
            android:exported="false" />

        <!-- 予定・課題の締切が近いときの定期通知（録音していないときも動く） -->
        <receiver
            android:name=".service.ReminderReceiver"
            android:exported="false" />

        <!-- リマインド通知の「了解」ボタン -->
        <receiver
            android:name=".net.ReminderAckReceiver"
            android:exported="false" />

        <!-- 設定時刻に「1日のまとめ」を通知する -->
        <receiver
            android:name=".service.DailyDigestReceiver"
            android:exported="false" />

        <!-- 端末再起動後にアラームを貼り直す（BOOT_COMPLETED はシステムのみ送信可） -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
